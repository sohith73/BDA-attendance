{
  "manifest_version": 3,
  "name": "FlashFire BDA Attendance",
  "version": "1.0",
  "description": "Auto-track BDA meeting attendance for Google Meet",
  "permissions": [
    "tabs",
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "BDA Attendance",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "panel.html",
        "panel.js",
        "styles.css",
        "exports.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
